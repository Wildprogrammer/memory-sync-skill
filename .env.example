# Memory Sync configuration

# OpenClaw workspace path
OPENCLAW_WORKSPACE=C:/Users/you/.openclaw/workspace

# Obsidian vault path
OBSIDIAN_VAULT_PATH=C:/Users/you/Documents/obsidian/vault

# Optional tuning
HIT_COOLDOWN_HOURS=24
S1_TTL_MIN_DAYS=3
S1_TTL_MAX_DAYS=10
NOISE_MIN_HITS=5
NOISE_DOMINANCE_RATIO=0.8
OPENCLAW_IMPORT_DISTILLED=true
CONTEXT_EXPORT_ENABLED=true
LEGACY_CONTEXT_ENABLED=false
DERIVED_OUTPUTS_ENABLED=true

# Review mode:
# agent = default, current agent reads review pack and writes decisions JSON.
# rules = use deterministic fallback only, saving agent tokens and allowing headless runs.
MEMORY_SYNC_REVIEW_MODE=agent

# Git/GitHub sync. Autopilot uses this only when enabled.
GIT_SYNC_ENABLED=false
GIT_PUSH_ENABLED=true
GIT_REMOTE=origin
# Leave blank to use the current checked-out branch.
GIT_BRANCH=
